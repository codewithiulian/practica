# Carolina2 voice sidecar — copy to .env and fill in. Never commit .env.
PORT=3100

# STT / brain / TTS providers
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional model + behaviour overrides (defaults match pinata-talk)
ANTHROPIC_BRAIN_MODEL=claude-opus-4-7
ANTHROPIC_REFLEX_MODEL=claude-haiku-4-5-20251001
ELEVENLABS_SPEED=1.0
DISABLE_REFLEX=0

# Supabase — used ONLY to verify the user's access token on the WS handshake.
# Same project as Pinata; anon key is sufficient for auth.getUser(token).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Comma-separated browser origins allowed to open the WS. Empty = allow all
# (dev only). In production set to e.g. https://your-pinata-domain.
CAROLINA2_ALLOWED_ORIGIN=
